// ============================================================================
// 设计令牌 - 单一数据源
// ============================================================================

:root {
  // ========== 颜色系统 ==========
  // 背景色
  --color-bg-primary: #ffffff;
  --color-bg-secondary: #f8f8f8;
  --color-bg-surface: rgba(245, 245, 245, 0.8);
  --color-bg-overlay: rgba(0, 0, 0, 0.05);

  // 文本色
  --color-text-primary: #1a1a1a;
  --color-text-secondary: #666666;
  --color-text-muted: #999999;
  --color-text-inverse: #ffffff;

  // 强调色
  --color-accent: #0066cc;
  --color-accent-hover: #0052a3;
  --color-accent-light: rgba(0, 102, 204, 0.1);

  // 边框色
  --color-border: rgba(0, 0, 0, 0.08);
  --color-border-hover: rgba(0, 0, 0, 0.15);

  // ========== 布局系统 ==========
  --content-max-width: 960px;
  --sidebar-width: 280px;
  --page-padding: 2rem;
  --gap: 1.5rem;

  // ========== 字体系统 ==========
  --font-family-base: "SF Pro Display", -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  --font-family-mono: "SF Mono", "Monaco", "Inconsolata", "Fira Code", monospace;

  --font-size-xs: 0.75rem;    // 12px
  --font-size-sm: 0.875rem;   // 14px
  --font-size-base: 1rem;     // 16px
  --font-size-lg: 1.125rem;   // 18px
  --font-size-xl: 1.25rem;    // 20px
  --font-size-2xl: 1.5rem;    // 24px
  --font-size-3xl: 2rem;      // 32px
  --font-size-4xl: 2.5rem;    // 40px

  --line-height-tight: 1.3;
  --line-height-base: 1.6;
  --line-height-relaxed: 1.8;

  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;

  // ========== 间距系统 ==========
  --spacing-xs: 0.25rem;   // 4px
  --spacing-sm: 0.5rem;    // 8px
  --spacing-md: 1rem;      // 16px
  --spacing-lg: 1.5rem;    // 24px
  --spacing-xl: 2rem;      // 32px
  --spacing-2xl: 3rem;     // 48px

  // ========== 圆角系统 ==========
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-xl: 16px;
  --radius-full: 9999px;

  // ========== 阴影系统 ==========
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.07);
  --shadow-lg: 0 10px 15px rgba(0, 0, 0, 0.1);
  --shadow-xl: 0 20px 25px rgba(0, 0, 0, 0.15);

  // ========== 过渡系统 ==========
  --transition-fast: 150ms ease;
  --transition-base: 250ms ease;
  --transition-slow: 350ms ease;

  // ========== Z-index 系统 ==========
  --z-dropdown: 100;
  --z-sticky: 200;
  --z-modal: 300;
  --z-tooltip: 400;

  // ========== 兼容旧变量（为README等页面） ==========
  --background-primary: var(--color-bg-primary);
  --background-primary-alt: var(--color-bg-secondary);
  --background-secondary: var(--color-bg-secondary);
  --background-modifier-border: var(--color-border);
  --text-normal: var(--color-text-primary);
  --text-muted: var(--color-text-secondary);
  --text-accent: var(--color-accent);
  --interactive-accent: var(--color-accent);
}

// ========== 深色主题（可选） ==========
[data-theme="dark"] {
  --color-bg-primary: #0a0a0a;
  --color-bg-secondary: #1a1a1a;
  --color-bg-surface: rgba(30, 30, 30, 0.8);
  --color-bg-overlay: rgba(255, 255, 255, 0.05);

  --color-text-primary: #f5f5f5;
  --color-text-secondary: #b0b0b0;
  --color-text-muted: #808080;
  --color-text-inverse: #0a0a0a;

  --color-border: rgba(255, 255, 255, 0.1);
  --color-border-hover: rgba(255, 255, 255, 0.2);

  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
  --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.4);
  --shadow-lg: 0 10px 15px rgba(0, 0, 0, 0.5);
  --shadow-xl: 0 20px 25px rgba(0, 0, 0, 0.6);
}
