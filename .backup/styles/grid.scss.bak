// ============================================================================
// 网格布局系统
// ============================================================================

// 主内容区域
.content-main {
  width: 100%;
  max-width: var(--content-max-width);
  margin: 0 auto;
  padding: var(--spacing-xl) var(--spacing-lg);
  min-height: 100vh;

  // 确保内容可选择
  user-select: text;

  @media (max-width: 1100px) {
    padding: var(--spacing-lg) var(--spacing-md);
  }
}

// 侧边栏
.sidebar {
  width: 100%;
  max-width: var(--sidebar-width);
  min-width: 200px;

  @media (max-width: 1100px) {
    max-width: 100%;
  }
}

.sidebar-left {
  position: sticky;
  top: var(--spacing-lg);
  height: fit-content;
  overflow-y: auto;
  max-height: calc(100vh - var(--spacing-2xl));

  @media (max-width: 1400px) {
    display: none;
  }
}

.sidebar-right {
  position: sticky;
  top: var(--spacing-lg);
  height: fit-content;
  overflow-y: auto;
  max-height: calc(100vh - var(--spacing-2xl));

  @media (max-width: 1100px) {
    position: relative;
    top: 0;
    max-height: none;
  }
}
